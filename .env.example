# EcoInsight - Environment Configuration Template
# copy this to .env.local for development

# --- SUPABASE CONFIGURATION (Core DB & Auth) ---
# Found in Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- SEARCH-SYNC v7 CONFIGURATION ---
# Alpha Vantage (Used for symbol resolution if direct map fails)
VITE_ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# --- EMAIL CONFIGURATION (Resend) ---
# Used for welcome emails and password resets
VITE_RESEND_API_KEY=re_your_resend_api_key

# --- AUTH CONFIGURATION (Custom JWT & OAuth) ---
# Generate a secure random string for JWT signing
JWT_SECRET=your-32-character-secret-key

# Google OAuth (Required for Google Login)
# Found in Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Apple OAuth (Required for Apple Login)
APPLE_ID_CLIENT_ID=com.your.app.bundle
APPLE_ID_TEAM_ID=your-team-id
APPLE_ID_KEY_ID=your-key-id
APPLE_ID_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# --- DEPLOYMENT & TELEMETRY ---
# Absolute URL of the application, used for OAuth callbacks and email links
VITE_APP_URL=http://localhost:5173

# Google Analytics 4 (Institutional Telemetry)
VITE_GA_ID=G-XXXXXXXXXX
