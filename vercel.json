{
  "rewrites": [
    {
      "source": "/v1/(.*)",
      "destination": "https://integrate.api.nvidia.com/v1/$1"
    },
    {
      "source": "/yahoo-finance/(.*)",
      "destination": "https://query1.finance.yahoo.com/$1"
    },
    {
      "source": "/google-finance/(.*)",
      "destination": "https://www.google.com/$1"
    },
    {
      "source": "/exchange-rates/(.*)",
      "destination": "https://api.exchangerate-api.com/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' 'unsafe-inline' 'unsafe-eval' https: data: blob:; img-src 'self' https: data: blob:; connect-src 'self' https: wss:;"
        }
      ]
    }
  ],
  "cleanUrls": true
}
